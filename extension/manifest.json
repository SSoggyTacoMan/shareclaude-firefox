{
    "manifest_version": 3,
    "name": "ShareClaude",
    "description": "Share your Claude chats with one click, preserving syntax highlighting for conversations",
    "version": "0.3.3",
    "permissions": [],
    "host_permissions": [
        "https://claude.ai/*"
    ],
    "icons": {
        "128": "images/icon-128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://claude.ai/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "shareclaude@shareclaude.pages.dev",
            "strict_min_version": "109.0"
        }
    }
}